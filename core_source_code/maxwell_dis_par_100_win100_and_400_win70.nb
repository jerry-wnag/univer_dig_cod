Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "777", "]"}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}], "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"1.", " ", "\:5e76\:53d1\:66b4\:80c0\:5f15\:64ce", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\:5b8c\:5168\:539f\:751f", " ", "Union", " ", "\:53bb\:91cd"}],
       "\:ff0c", "\:65e0\:4eba\:5de5\:6392\:5e8f\:5e72\:9884"}], ")"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"StepEvolution", "[", 
     RowBox[{"g_Graph", ",", "window_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "allEdges", ",", "activeEdges", ",", "nActive", ",", "usedEdges", ",", 
        "updates", ",", "tempE1", ",", "tempE2", ",", "x", ",", "y", ",", "z",
         ",", "wCounter", ",", "newVertices", ",", "newActive", ",", 
        "newFrozen", ",", "remainingEdges"}], "}"}], ",", 
      RowBox[{
       RowBox[{"allEdges", "=", 
        RowBox[{"EdgeList", "[", "g", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"activeEdges", "=", 
        RowBox[{"RandomSample", "[", 
         RowBox[{"Cases", "[", 
          RowBox[{"allEdges", ",", "_UndirectedEdge"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nActive", "=", 
        RowBox[{"Length", "[", "activeEdges", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"nActive", "<", "2"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{"g", ",", "0"}], "}"}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"usedEdges", "=", 
        RowBox[{"{", "}"}]}], ";", 
       RowBox[{"updates", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"tempE1", "=", 
           RowBox[{"activeEdges", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"MemberQ", "[", 
              RowBox[{"usedEdges", ",", "tempE1"}], "]"}]}], ",", 
            RowBox[{"Do", "[", 
