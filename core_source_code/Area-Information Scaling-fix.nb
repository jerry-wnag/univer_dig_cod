Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "]"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"1.", " ", "\:4e25\:683c\:6f14\:5316\:5f15\:64ce", " ", 
    RowBox[{"(", 
     RowBox[{"Strict", " ", "Evolution", " ", "Engine"}], ")"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"StepEvolution", "[", "g_Graph", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "allEdges", ",", "activeEdges", ",", "candidates", ",", "e1", ",", 
        "e2", ",", "x", ",", "y", ",", "z", ",", "w", ",", "maxNode", ",", 
        "newActive", ",", "newInert", ",", "remainingEdges"}], "}"}], ",", 
      RowBox[{
       RowBox[{"allEdges", "=", 
        RowBox[{"EdgeList", "[", "g", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"activeEdges", "=", 
        RowBox[{"Cases", "[", 
         RowBox[{"allEdges", ",", "_UndirectedEdge"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "activeEdges", "]"}], "<", "2"}], ",", 
         RowBox[{"Return", "[", "g", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"candidates", "=", 
        RowBox[{"RandomSample", "[", "activeEdges", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"e1", "=", 
           RowBox[{"candidates", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"e2", "=", 
              RowBox[{"candidates", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Length", "[", 
                 RowBox[{"Intersection", "[", 
                  RowBox[{
                   RowBox[{"List", "@@", "e1"}], ",", 
                   RowBox[{"List", "@@", "e2"}]}], "]"}], "]"}], "==", "1"}], 
               ",", 
               RowBox[{"Goto", "[", "\"\<Found\>\"", "]"}]}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", 
              RowBox[{"i", "+", "1"}], ",", 
              RowBox[{"Min", "[", 
               RowBox[{
                RowBox[{"i", "+", "10"}], ",", 
                RowBox[{"Length", "[", "candidates", "]"}]}], "]"}]}], 
             "}"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "candidates", "]"}]}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Return", "[", "g", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Label", "[", "\"\<Found\>\"", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"y", "=", 
        RowBox[{
         RowBox[{"Intersection", "[", 
          RowBox[{
           RowBox[{"List", "@@", "e1"}], ",", 
           RowBox[{"List", "@@", "e2"}]}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"x", "=", 
        RowBox[{
         RowBox[{"Complement", "[", 
          RowBox[{
           RowBox[{"List", "@@", "e1"}], ",", 
           RowBox[{"{", "y", "}"}]}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"z", "=", 
        RowBox[{
         RowBox[{"Complement", "[", 
          RowBox[{
           RowBox[{"List", "@@", "e2"}], ",", 
           RowBox[{"{", "y", "}"}]}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"maxNode", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"VertexList", "[", "g", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"w", "=", 
        RowBox[{"maxNode", "+", "1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"newActive", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"UndirectedEdge", "[", 
           RowBox[{"x", ",", "z"}], "]"}], ",", 
          RowBox[{"UndirectedEdge", "[", 
           RowBox[{"x", ",", "w"}], "]"}], ",", 
          RowBox[{"UndirectedEdge", "[", 
           RowBox[{"w", ",", "z"}], "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newInert", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"DirectedEdge", "[", 
           RowBox[{"x", ",", "y"}], "]"}], ",", 
          RowBox[{"DirectedEdge", "[", 
           RowBox[{"y", ",", "z"}], "]"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"remainingEdges", "=", 
        RowBox[{"Complement", "[", 
         RowBox[{"allEdges", ",", 
          RowBox[{"{", 
           RowBox[{"e1", ",", "e2"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"\:3010", "\:6838\:5fc3\:4fee\:6539", "\:3011"}], "\:ff1a", 
         RowBox[{
         "\:4ec5\:5728\:6b64\:5904\:4f7f\:7528", " ", "Union", " ", 
          "\:53bb\:91cd"}], "\:ff0c", 
         "\:5176\:4f59\:903b\:8f91\:5b8c\:5168\:4fdd\:7559\:4f60\:7684\:539f\
\:59cb\:4ee3\:7801"}], "*)"}], 
       RowBox[{"Graph", "[", 
        RowBox[{
         RowBox[{"Union", "[", 
          RowBox[{
           RowBox[{"VertexList", "[", "g", "]"}], ",", 
           RowBox[{"{", "w", "}"}]}], "]"}], ",", 
         RowBox[{"Union", "[", 
          RowBox[{"remainingEdges", ",", "newInert", ",", "newActive"}], 
          "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"2.", " ", "\:5168\:606f\:626b\:63cf\:4eea", " ", 
    RowBox[{"(", 
     RowBox[{"Holographic", " ", "Scanner"}], ")"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ScanBlackHole", "[", "g_Graph", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "simpleG", ",", "center", ",", "dists", ",", "maxR", ",", "scanData", ",",
         "nodesInside", ",", "subgraphInside", ",", "AreaA", ",", "InfoS", ",",
         "activeEdges"}], "}"}], ",", 
      RowBox[{
       RowBox[{"simpleG", "=", 
        RowBox[{"Graph", "[", 
         RowBox[{"UndirectedEdge", "@@@", 
          RowBox[{"EdgeList", "[", "g", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"center", "=", 
        RowBox[{"First", "[", 
         RowBox[{"SortBy", "[", 
          RowBox[{
           RowBox[{"VertexList", "[", "simpleG", "]"}], ",", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"VertexDegree", "[", 
              RowBox[{"simpleG", ",", "#"}], "]"}]}], "&"}]}], "]"}], "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"dists", "=", 
        RowBox[{
         RowBox[{"GraphDistance", "[", 
          RowBox[{"simpleG", ",", "center"}], "]"}], "/.", " ", 
         RowBox[{"Infinity", "->", "0"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"maxR", "=", 
        RowBox[{"Max", "[", "dists", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"scanData", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"nodesInside", "=", 
           RowBox[{"Pick", "[", 
            RowBox[{
             RowBox[{"VertexList", "[", "g", "]"}], ",", 
             RowBox[{"UnitStep", "[", 
              RowBox[{"r", "-", "dists"}], "]"}], ",", "1"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"subgraphInside", "=", 
           RowBox[{"Subgraph", "[", 
            RowBox[{"g", ",", "nodesInside"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"InfoS", "=", 
           RowBox[{"Count", "[", 
            RowBox[{
             RowBox[{"EdgeList", "[", "subgraphInside", "]"}], ",", 
             "_DirectedEdge"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"AreaA", "=", "0"}], ";", "\[IndentingNewLine]", 
          RowBox[{"activeEdges", "=", 
           RowBox[{"Cases", "[", 
            RowBox[{
             RowBox[{"EdgeList", "[", "g", "]"}], ",", "_UndirectedEdge"}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"\:3010", "\:5173\:952e\:70b9", "\:3011"}], "\:ff1a", 
            RowBox[{
            "\:4fdd\:7559\:4f60\:539f\:6765\:7684", "||", "\:903b\:8f91"}], "\:ff0c",
             "\:8fd9\:80fd\:4ea7\:751f\:4f60\:60f3\:8981\:7684\:76f4\:7ebf\
\:7ed3\:679c"}], "*)"}], 
          RowBox[{"AreaA", "=", 
           RowBox[{"Count", "[", 
            RowBox[{"activeEdges", ",", 
             RowBox[{
              RowBox[{"UndirectedEdge", "[", 
               RowBox[{"u_", ",", "v_"}], "]"}], "/;", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"MemberQ", "[", 
                 RowBox[{"nodesInside", ",", "u"}], "]"}], "||", 
                RowBox[{"MemberQ", "[", 
                 RowBox[{"nodesInside", ",", "v"}], "]"}]}], ")"}]}]}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"AreaA", ">", "0"}], "&&", 
             RowBox[{"InfoS", ">", "0"}]}], ",", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"scanData", ",", 
              RowBox[{"{", 
               RowBox[{"AreaA", ",", "InfoS"}], "}"}]}], "]"}]}], "]"}], 
          ";"}], ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", "1", ",", 
           RowBox[{"maxR", "-", "1"}]}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", "scanData"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"3.", " ", "\:8fd0\:884c\:5b9e\:9a8c"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"RunHolographicTest", "[", "steps_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "universe", ",", "data", ",", "fit", ",", "plot", ",", "slope"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"universe", "=", 
        RowBox[{"CycleGraph", "[", 
         RowBox[{"4", ",", 
          RowBox[{"DirectedEdges", "->", "False"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<\|01f573\:fe0f Generating AdS black hole... Evolution \>\
\"", ",", "steps", ",", "\"\< steps\>\""}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Monitor", "[", 
        RowBox[{
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{"universe", "=", 
            RowBox[{"StepEvolution", "[", "universe", "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "steps"}], "}"}]}], "]"}], ",", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           
           RowBox[{"\"\<Progress: \>\"", ",", "i", ",", "\"\</\>\"", ",", 
            "steps", ",", "\"\< | Nodes: \>\"", ",", 
            RowBox[{"VertexCount", "[", "universe", "]"}]}], "}"}], "]"}]}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
       "Print", 
        "[", "\"\<Evolution completed. Holistic tomography scan in \
progress....\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"ScanBlackHole", "[", "universe", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"SortBy", "[", 
         RowBox[{"data", ",", "First"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "data", "]"}], "<", "5"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", "\"\<Insufficient data.\>\"", "]"}], ";", 
          RowBox[{"Return", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"fit", "=", 
        RowBox[{"LinearModelFit", "[", 
         RowBox[{"data", ",", "x", ",", "x"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "\:63d0\:53d6\:659c\:7387", "\:ff1a", 
         "\:4f7f\:7528\:6807\:51c6\:65b9\:6cd5\:83b7\:53d6\:6570\:503c"}], 
        "*)"}], 
       RowBox[{"slope", "=", 
        RowBox[{
         RowBox[{"fit", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
       "Print", 
        "[", "\"\<\\n\|01f4d0 Holographic coefficient determination:\>\"", 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"Style", "[", 
         RowBox[{
          RowBox[{"\"\<slope = \>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"NumberForm", "[", 
             RowBox[{"slope", ",", 
              RowBox[{"{", 
               RowBox[{"4", ",", "3"}], "}"}]}], "]"}], "]"}]}], ",", "Red", ",",
           "Bold", ",", "16"}], "]"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<\:62df\:5408\:4f18\:5ea6 R^2 = \>\"", ",", 
         RowBox[{"fit", "[", "\"\<RSquared\>\"", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"Show", "[", 
         RowBox[{
          RowBox[{"ListPlot", "[", 
           RowBox[{"data", ",", 
            RowBox[{"PlotStyle", "->", 
             RowBox[{"{", 
              RowBox[{"Blue", ",", 
               RowBox[{"PointSize", "[", "0.015", "]"}]}], "}"}]}], ",", 
            RowBox[{"AxesLabel", "->", 
             RowBox[{"{", 
              RowBox[{"\"\<Area (A)\>\"", ",", "\"\<Information (S)\>\""}], 
              "}"}]}], ",", 
            RowBox[{"PlotLabel", "->", 
             RowBox[{"Style", "[", 
              
              RowBox[{"\"\<Holographic Principle: S vs A\>\"", ",", "Bold", ",",
                "14"}], "]"}]}], ",", 
            RowBox[{"GridLines", "->", "Automatic"}], ",", 
            RowBox[{"Frame", "->", "True"}]}], "]"}], ",", 
          RowBox[{"Plot", "[", 
           RowBox[{
            RowBox[{"fit", "[", "x", "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "0", ",", 
              RowBox[{"Max", "[", 
               RowBox[{"data", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], "}"}], ",", 
            RowBox[{"PlotStyle", "->", 
             RowBox[{"{", 
              RowBox[{"Red", ",", "Dashed", ",", "Thick"}], "}"}]}]}], "]"}], 
          ",", 
          RowBox[{"Epilog", "->", 
           RowBox[{"{", 
            RowBox[{"Inset", "[", 
             RowBox[{
              RowBox[{"Framed", "[", 
               RowBox[{
                RowBox[{"Style", "[", 
                 RowBox[{"\"\<S \[Proportional] A (Linear Confirmed)\>\"", ",", 
                  RowBox[{"Darker", "[", "Green", "]"}], ",", "Bold"}], "]"}],
                 ",", 
                RowBox[{"Background", "->", "White"}]}], "]"}], ",", 
              RowBox[{"Scaled", "[", 
               RowBox[{"{", 
                RowBox[{"0.3", ",", "0.8"}], "}"}], "]"}]}], "]"}], "}"}]}], ",", 
          RowBox[{"ImageSize", "->", "500"}]}], "]"}], "]"}], ";"}]}], 
     "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"\:8fd0\:884c", " ", "400", " ", "\:6b65\:6d4b\:8bd5"}], 
