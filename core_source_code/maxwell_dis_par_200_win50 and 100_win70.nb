             RowBox[{"Log", "[", "t", "]"}]}], "+", "phi"}], "]"}]}]}], 
        ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nlmDiscrete", "=", 
      RowBox[{"Check", "[", 
       RowBox[{
        RowBox[{"NonlinearModelFit", "[", 
         RowBox[{"adultData", ",", 
          RowBox[{"{", 
           RowBox[{"discreteModel", ",", 
            RowBox[{
             RowBox[{"k", ">", "0"}], "&&", 
             RowBox[{"0.8", "<", "alpha", "<", "1.2"}], "&&", 
             RowBox[{"a", ">", "0"}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"w0", ",", "w0Init"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "0.5"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"alpha", ",", "1.0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"a", ",", "0.01"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"omega", ",", "15"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"phi", ",", "0"}], "}"}]}], "}"}], ",", "t", ",", 
          RowBox[{"MaxIterations", "->", "1500"}], ",", 
          RowBox[{"Method", "->", "\"\<NMinimize\>\""}]}], "]"}], ",", 
        "$Failed"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"plotSnowflake", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"nlmDiscrete", "=!=", "$Failed"}], ",", 
        RowBox[{
         RowBox[{"r2", "=", 
          RowBox[{"nlmDiscrete", "[", "\"\<RSquared\>\"", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"residuals", "=", 
          RowBox[{"nlmDiscrete", "[", "\"\<FitResiduals\>\"", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"ListPlot", "[", 
          RowBox[{"residuals", ",", 
           RowBox[{"PlotStyle", "->", 
            RowBox[{"{", 
             RowBox[{"Red", ",", 
              RowBox[{"PointSize", "[", "0.025", "]"}]}], "}"}]}], ",", 
           RowBox[{"Frame", "->", "True"}], ",", 
           RowBox[{"FrameLabel", "->", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Concurrent Steps\>\"", 
              ",", "\"\<Residual Error\>\""}], "}"}]}], ",", 
           RowBox[{"PlotLabel", "->", 
            RowBox[{"Style", "[", 
             
             RowBox[{"\"\<Discrete Parallel Residuals\>\"", ",", "14", ",", 
              "Bold"}], "]"}]}], ",", 
           RowBox[{"Epilog", "->", 
            RowBox[{"{", 
             RowBox[{"Text", "[", 
              RowBox[{
               RowBox[{"Style", "[", 
                RowBox[{
                 
                 RowBox[{"\"\<\\!\\(\\*SuperscriptBox[\\(R\\), \\(2\\)]\\) = \
\>\"", "<>", 
                  RowBox[{"ToString", "[", 
                   RowBox[{"NumberForm", "[", 
                    RowBox[{"r2", ",", 
                    RowBox[{"{", 
                    RowBox[{"5", ",", "6"}], "}"}]}], "]"}], "]"}]}], ",", 
                 "Black", ",", "12"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Length", "[", "adultData", "]"}], "*", "0.7"}], ",", 
                 RowBox[{
                  RowBox[{"Max", "[", "residuals", "]"}], "*", "0.8"}]}], 
                "}"}]}], "]"}], "}"}]}], ",", 
           RowBox[{"GridLines", "->", 
            RowBox[{"{", 
             RowBox[{"None", ",", 
              RowBox[{"{", "0", "}"}]}], "}"}]}], ",", 
           RowBox[{"ImageSize", "->", "450"}]}], "]"}]}], ",", 
        RowBox[{"Graphics", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Text", "[", "\"\<Fit Failed\>\"", "]"}], "}"}], ",", 
          RowBox[{"ImageSize", "->", "450"}]}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"Rasterize", "[", 
       RowBox[{
        RowBox[{"Grid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"plotWavePacket", ",", "plotSnowflake"}], "}"}], "}"}], ",", 
          RowBox[{"Spacings", "->", 
           RowBox[{"{", 
            RowBox[{"2", ",", "0"}], "}"}]}]}], "]"}], ",", 
        RowBox[{"ImageResolution", "->", "100"}]}], "]"}], "]"}], ";"}], ",", 
    RowBox[{"Print", "[", "\"\<\:6570\:636e\:4e0d\:8db3\:3002\>\"", "]"}]}], 
