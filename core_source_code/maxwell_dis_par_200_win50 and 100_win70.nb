     RowBox[{"discreteModel", "=", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"w0", "^", "2"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"k", "*", 
            RowBox[{"t", "^", "alpha"}]}], ")"}], "^", "2"}]}], "]"}], "*", 
       RowBox[{"(", 
