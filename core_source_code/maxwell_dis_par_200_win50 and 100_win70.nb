 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"StepEvolution", "[", 
     RowBox[{"g_Graph", ",", "window_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "allEdges", ",", "activeEdges", ",", "nActive", ",", "usedEdges", ",", 
        "updates", ",", "tempE1", ",", "tempE2", ",", "x", ",", "y", ",", "z",
         ",", "wCounter", ",", "newVertices", ",", "newActive", ",", 
        "newFrozen", ",", "remainingEdges"}], "}"}], ",", 
      RowBox[{
       RowBox[{"allEdges", "=", 
        RowBox[{"EdgeList", "[", "g", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"activeEdges", "=", 
        RowBox[{"RandomSample", "[", 
         RowBox[{"Cases", "[", 
          RowBox[{"allEdges", ",", "_UndirectedEdge"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nActive", "=", 
        RowBox[{"Length", "[", "activeEdges", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"nActive", "<", "2"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{"g", ",", "0"}], "}"}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"usedEdges", "=", 
        RowBox[{"{", "}"}]}], ";", 
       RowBox[{"updates", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"tempE1", "=", 
           RowBox[{"activeEdges", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"MemberQ", "[", 
              RowBox[{"usedEdges", ",", "tempE1"}], "]"}]}], ",", 
            RowBox[{"Do", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"tempE2", "=", 
                RowBox[{"activeEdges", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"!", 
                   RowBox[{"MemberQ", "[", 
                    RowBox[{"usedEdges", ",", "tempE2"}], "]"}]}], "&&", 
                  RowBox[{
                   RowBox[{"Length", "[", 
                    RowBox[{"Intersection", "[", 
                    RowBox[{
                    RowBox[{"List", "@@", "tempE1"}], ",", 
                    RowBox[{"List", "@@", "tempE2"}]}], "]"}], "]"}], "==", 
                   "1"}]}], ",", 
                 RowBox[{
                  RowBox[{"AppendTo", "[", 
                   RowBox[{"updates", ",", 
                    RowBox[{"{", 
                    RowBox[{"tempE1", ",", "tempE2"}], "}"}]}], "]"}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"AppendTo", "[", 
                   RowBox[{"usedEdges", ",", "tempE1"}], "]"}], ";", 
                  RowBox[{"AppendTo", "[", 
                   RowBox[{"usedEdges", ",", "tempE2"}], "]"}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"Break", "[", "]"}], ";"}]}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", 
                RowBox[{"i", "+", "1"}], ",", 
                RowBox[{"Min", "[", 
                 RowBox[{
                  RowBox[{"i", "+", "window"}], ",", "nActive"}], "]"}]}], 
               "}"}]}], "]"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "nActive"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "updates", "]"}], "==", "0"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{"g", ",", "0"}], "}"}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"wCounter", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"VertexList", "[", "g", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"newVertices", "=", 
        RowBox[{"{", "}"}]}], ";", 
       RowBox[{"newActive", "=", 
        RowBox[{"{", "}"}]}], ";", 
       RowBox[{"newFrozen", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "=", 
           RowBox[{
            RowBox[{"Intersection", "[", 
             RowBox[{
              RowBox[{"List", "@@", 
               RowBox[{"pair", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], ",", 
              RowBox[{"List", "@@", 
               RowBox[{"pair", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"x", "=", 
           RowBox[{
            RowBox[{"Complement", "[", 
             RowBox[{
              RowBox[{"List", "@@", 
               RowBox[{"pair", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], ",", 
              RowBox[{"{", "y", "}"}]}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"z", "=", 
           RowBox[{
            RowBox[{"Complement", "[", 
             RowBox[{
              RowBox[{"List", "@@", 
               RowBox[{"pair", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], ",", 
              RowBox[{"{", "y", "}"}]}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"wCounter", "++"}], ";", "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"newVertices", ",", "wCounter"}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"newActive", "=", 
           RowBox[{"Join", "[", 
            RowBox[{"newActive", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"UndirectedEdge", "[", 
                RowBox[{"x", ",", "z"}], "]"}], ",", 
               RowBox[{"UndirectedEdge", "[", 
                RowBox[{"x", ",", "wCounter"}], "]"}], ",", 
               RowBox[{"UndirectedEdge", "[", 
                RowBox[{"wCounter", ",", "z"}], "]"}]}], "}"}]}], "]"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"newFrozen", "=", 
           RowBox[{"Join", "[", 
            RowBox[{"newFrozen", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"DirectedEdge", "[", 
                RowBox[{"x", ",", "y"}], "]"}], ",", 
               RowBox[{"DirectedEdge", "[", 
                RowBox[{"y", ",", "z"}], "]"}]}], "}"}]}], "]"}]}], ";"}], ",", 
         RowBox[{"{", 
          RowBox[{"pair", ",", "updates"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"remainingEdges", "=", 
        RowBox[{"Complement", "[", 
         RowBox[{"allEdges", ",", 
          RowBox[{"Flatten", "[", "updates", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Graph", "[", 
          RowBox[{
           RowBox[{"Union", "[", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"VertexList", "[", "g", "]"}], ",", "newVertices"}], 
             "]"}], "]"}], ",", 
           RowBox[{"Union", "[", 
            RowBox[{"Join", "[", 
             RowBox[{"remainingEdges", ",", "newActive", ",", "newFrozen"}], 
             "]"}], "]"}]}], "]"}], ",", 
         RowBox[{"Length", "[", "updates", "]"}]}], "}"}]}]}], "]"}]}], ";"}],
