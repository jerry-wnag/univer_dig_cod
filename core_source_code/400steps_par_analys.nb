Cell[BoxData[{
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<[1/5] \:6b63\:5728\:6784\:5efa\:5168\:91cf\:65e0\:5411\:65f6\
\:7a7a\:9aa8\:67b6...\>\"", ",", "Blue", ",", "Bold"}], "]"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fullUndirectedGraph", "=", 
    RowBox[{"Graph", "[", 
     RowBox[{
      RowBox[{"VertexList", "[", "universe", "]"}], ",", 
      RowBox[{"UndirectedEdge", "@@@", 
       RowBox[{"EdgeList", "[", "universe", "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<[2/5] \:6b63\:5728\:5b9a\:4f4d\:5927\:7206\:70b8\:5947\:70b9\
\:5e76\:63d0\:53d6\:8fb9\:7f18\:539a\:5757...\>\"", ",", "Blue", ",", 
     "Bold"}], "]"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"seedNode", "=", 
   RowBox[{"First", "[", 
    RowBox[{"VertexList", "[", "fullUndirectedGraph", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"distances", "=", 
   RowBox[{"GraphDistance", "[", 
    RowBox[{"fullUndirectedGraph", ",", "seedNode"}], "]"}]}], ";"}], "\n", 
